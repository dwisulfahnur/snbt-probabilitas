---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SNBT Peluang Masuk PTN</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header fade-in">
    <div class="header-badge">
      <span class="dot"></span>
      SNBT 2026 · Data Resmi Sidatagrun
    </div>
    <h1>Cek <em>Peluang</em> Masuk<br>Prodi PTN Impianmu</h1>
    <p class="subtitle">Pilih universitas untuk melihat estimasi peluang diterima berdasarkan daya tampung 2026 dan jumlah peminat 2025.</p>
  </div>

  <!-- SEARCH CARD -->
  <div class="search-section fade-in" style="animation-delay:.08s">
    <div class="search-card">
      <label class="search-label">Pilih Universitas</label>

      <!-- Selected display -->
      <div class="selected-uni" id="selected-display">
        <span class="selected-uni-kode" id="sel-kode"></span>
        <div class="selected-uni-info">
          <div class="selected-uni-nama" id="sel-nama"></div>
          <div class="selected-uni-loc" id="sel-loc"></div>
        </div>
      </div>

      <!-- Combobox -->
      <div class="combobox-wrap" id="combobox-wrap">
        <div class="combobox-input-row">
          <input
            class="combobox-input"
            id="uni-search"
            type="text"
            placeholder="🔍  Ketik nama atau kode universitas..."
            autocomplete="off"
            spellcheck="false"
          >
          <button class="combobox-clear" id="btn-clear" title="Hapus pilihan">✕</button>
        </div>
        <div class="dropdown" id="dropdown"></div>
      </div>

      <button id="btn-load" disabled>Pilih universitas terlebih dahulu</button>
    </div>
  </div>

  <!-- ERROR -->
  <div id="error-area"></div>

  <!-- LOADING -->
  <div id="status-area">
    <div class="spinner"></div>
    <div class="status-text" id="status-text">Mengambil data...</div>
  </div>

  <!-- PTN INFO -->
  <div id="ptn-info">
    <div class="ptn-title" id="ptn-name">—</div>
    <div class="ptn-meta">
      <div class="ptn-meta-item">📍 <span id="ptn-kota">—</span></div>
      <div class="ptn-meta-item">🏛 <span id="ptn-prodi-count">—</span></div>
      <div class="ptn-meta-item">🔗 <a id="ptn-web" href="#" target="_blank" style="color:var(--accent);font-size:12px">Website Resmi</a></div>
    </div>
  </div>

  <!-- SUMMARY -->
  <div id="summary-area">
    <div class="summary-grid">
      <div class="stat-card total"><div class="stat-label">Total Prodi</div><div class="stat-val" id="s-total">0</div><div class="stat-sub">dengan data peminat</div></div>
      <div class="stat-card high"><div class="stat-label">Peluang Tinggi</div><div class="stat-val" id="s-high">0</div><div class="stat-sub">≥ 30%</div></div>
      <div class="stat-card mid"><div class="stat-label">Peluang Sedang</div><div class="stat-val" id="s-mid">0</div><div class="stat-sub">10% – 30%</div></div>
      <div class="stat-card low"><div class="stat-label">Peluang Ketat</div><div class="stat-val" id="s-low">0</div><div class="stat-sub">< 10%</div></div>
    </div>
  </div>

  <!-- CONTROLS -->
  <div id="controls-area">
    <div class="controls-row">
      <input class="ctrl-search" id="q-search" type="text" placeholder="🔍  Cari nama prodi...">
      <select class="ctrl-select" id="q-jenjang">
        <option value="">Semua jenjang</option>
        <option value="Sarjana">S1 – Sarjana</option>
        <option value="Sarjana Terapan">D4 – Sarjana Terapan</option>
      </select>
      <select class="ctrl-select" id="q-filter">
        <option value="">Semua peluang</option>
        <option value="high">Tinggi ≥30%</option>
        <option value="mid">Sedang 10–30%</option>
        <option value="low">Ketat &lt;10%</option>
      </select>
      <select class="ctrl-select" id="q-sort">
        <option value="p_desc">Peluang tertinggi</option>
        <option value="p_asc">Peluang terendah</option>
        <option value="peminat_desc">Peminat terbanyak</option>
        <option value="tampung_desc">Daya tampung terbesar</option>
        <option value="nama">Nama A–Z</option>
      </select>
      <span class="row-count" id="row-count"></span>
    </div>
  </div>

  <!-- TABLE -->
  <div id="table-area">
    <div class="tbl-wrap fade-in">
      <table>
        <thead>
          <tr>
            <th style="width:36%" data-sort="nama" id="th-nama">Nama Prodi <span class="arr">↕</span></th>
            <th style="width:8%" data-sort="tampung_desc" id="th-tampung">Tampung <span class="arr">↕</span></th>
            <th style="width:9%" data-sort="peminat_desc" id="th-peminat">Peminat <span class="arr">↕</span></th>
            <th style="width:8%">Jenjang</th>
            <th style="width:12%" data-sort="p_desc" id="th-peluang">Peluang <span class="arr">↕</span></th>
            <th style="width:27%">Visualisasi</th>
          </tr>
        </thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
    <p class="note">
      <strong>Cara baca:</strong> Peluang = Daya Tampung 2026 ÷ Peminat 2025 × 100%. Ini estimasi kasar berbasis rasio — semakin tinggi, semakin longgar persaingannya. Nilai UTBK tetap menjadi penentu utama kelulusan seleksi SNBT.
    </p>
  </div>

</div>

<script>
// ── DATA UNIVERSITAS ─────────────────────────────────────────────────────────
