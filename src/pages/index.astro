a":"UNIVERSITAS NEGERI MAKASSAR","kota":"Kota Makassar","provinsi":"Sulawesi Selatan"},{"kode":"1718","nama":"INSTITUT TEKNOLOGI BJ. HABIBIE SULAWESI SELATAN","kota":"Kota Parepare","provinsi":"Sulawesi Selatan"},{"kode":"1721","nama":"UNIVERSITAS SAM RATULANGI","kota":"Kota Manado","provinsi":"Sulawesi Utara"},{"kode":"1722","nama":"UNIVERSITAS NEGERI MANADO","kota":"Kabupaten Minahasa","provinsi":"Sulawesi Utara"},{"kode":"1731","nama":"UNIVERSITAS TADULAKO","kota":"Kota Palu","provinsi":"Sulawesi Tengah"},{"kode":"1741","nama":"UNIVERSITAS SULAWESI BARAT","kota":"Kabupaten Majene","provinsi":"Sulawesi Barat"},{"kode":"1751","nama":"UNIVERSITAS HALUOLEO","kota":"Kota Kendari","provinsi":"Sulawesi Tenggara"},{"kode":"1752","nama":"UNIVERSITAS NEGERI GORONTALO","kota":"Kota Gorontalo","provinsi":"Gorontalo"},{"kode":"1753","nama":"UNIVERSITAS SEMBILAN BELAS NOVEMBER KOLAKA","kota":"Kabupaten Kolaka","provinsi":"Sulawesi Tenggara"},{"kode":"1811","nama":"UNIVERSITAS PATTIMURA","kota":"Kota Ambon","provinsi":"Maluku"},{"kode":"1821","nama":"UNIVERSITAS KHAIRUN","kota":"Kota Ternate","provinsi":"Maluku Utara"},{"kode":"1911","nama":"UNIVERSITAS CENDERAWASIH","kota":"Kota Jayapura","provinsi":"Papua"},{"kode":"1912","nama":"UNIVERSITAS MUSAMUS MERAUKE","kota":"Kabupaten Merauke","provinsi":"Papua Selatan"},{"kode":"1913","nama":"ISBI TANAH PAPUA","kota":"Kabupaten Jayapura","provinsi":"Papua"},{"kode":"1921","nama":"UNIVERSITAS PAPUA","kota":"Kabupaten Manokwari","provinsi":"Papua Barat"}];

// ── STATE ────────────────────────────────────────────────────────────────────
let selectedUni = null;
let ddActiveIdx = -1;
let ddFiltered = [];
let allData = [];
let currentSort = 'p_desc';

// ── DOM REFS ─────────────────────────────────────────────────────────────────
const searchEl   = document.getElementById('uni-search');
const dropdown   = document.getElementById('dropdown');
const btnClear   = document.getElementById('btn-clear');
const btnLoad    = document.getElementById('btn-load');
const selDisplay = document.getElementById('selected-display');

// ── COMBOBOX ─────────────────────────────────────────────────────────────────
function highlight(text, q) {
  if (!q) return text;
  const idx = text.toLowerCase().indexOf(q.toLowerCase());
  if (idx === -1) return text;
  return text.slice(0, idx) + '<mark>' + text.slice(idx, idx + q.length) + '</mark>' + text.slice(idx + q.length);
}

function renderDropdown(q) {
  if (!q && selectedUni) { dropdown.classList.remove('open'); return; }

  const ql = q.toLowerCase();
  ddFiltered = UNIS.filter(u =>
    u.nama.toLowerCase().includes(ql) ||
    u.kode.includes(ql) ||
    u.kota.toLowerCase().includes(ql) ||
    u.provinsi.toLowerCase().includes(ql)
  );
  ddActiveIdx = -1;

  if (ddFiltered.length === 0) {
    dropdown.innerHTML = `<div class="dd-empty">Tidak ada universitas yang cocok.</div>`;
    dropdown.classList.add('open');
    return;
  }

  const groups = {};
  ddFiltered.forEach(u => {
    if (!groups[u.provinsi]) groups[u.provinsi] = [];
    groups[u.provinsi].push(u);
  });

  let html = '';
  Object.entries(groups).forEach(([prov, unis]) => {
    html += `<div class="dd-group-label">${prov}</div>`;
    unis.forEach(u => {
      const isSelected = selectedUni && selectedUni.kode === u.kode;
      html += `<div class="dd-item${isSelected ? ' selected' : ''}" data-kode="${u.kode}">
        <span class="dd-kode">${u.kode}</span>
        <div class="dd-info">
          <div class="dd-nama">${highlight(u.nama, q)}</div>
          <div class="dd-sub">${u.kota}</div>
        </div>
      </div>`;
    });
  });

  dropdown.innerHTML = html;
  dropdown.classList.add('open');
}

function selectUni(kode) {
  const u = UNIS.find(x => x.kode === kode);
  if (!u) return;
  selectedUni = u;
  searchEl.value = u.nama;
  dropdown.classList.remove('open');
  btnClear.classList.add('visible');

  document.getElementById('sel-kode').textContent = u.kode;
  document.getElementById('sel-nama').textContent = u.nama;
  document.getElementById('sel-loc').textContent = `${u.kota} · ${u.provinsi}`;
  selDisplay.classList.add('show');

  btnLoad.disabled = false;
  btnLoad.textContent = `Lihat Prodi ${u.nama.split(' ').slice(0, 3).join(' ')} →`;

  hideResults();
  setError(null);
}

function clearSelection() {
  selectedUni = null;
  searchEl.value = '';
  btnClear.classList.remove('visible');
  selDisplay.classList.remove('show');
  btnLoad.disabled = true;
  btnLoad.textContent = 'Pilih universitas terlebih dahulu';
  dropdown.classList.remove('open');
  hideResults();
  setError(null);
  searchEl.focus();
}

function hideResults() {
  allData = [];
  ['ptn-info', 'summary-area', 'controls-area', 'table-area'].forEach(id => {
    document.getElementById(id).style.display = 'none';
  });
}

// ── EVENT LISTENERS ───────────────────────────────────────────────────────────
btnClear.addEventListener('click', clearSelection);
btnLoad.addEventListener('click', loadData);
document.getElementById('q-search').addEventListener('input', render);
['q-jenjang', 'q-filter', 'q-sort'].forEach(id => {
  document.getElementById(id).addEventListener('change', render);
});

// Dropdown click delegation
dropdown.addEventListener('click', e => {
  const item = e.target.closest('.dd-item');
  if (item) selectUni(item.dataset.kode);
});

// Table header sort delegation
document.querySelector('thead').addEventListener('click', e => {
  const th = e.target.closest('th[data-sort]');
  if (th) setSort(th.dataset.sort);
});

// Keyboard nav
searchEl.addEventListener('keydown', e => {
  const items = dropdown.querySelectorAll('.dd-item');
  if (!dropdown.classList.contains('open')) {
    if (e.key === 'ArrowDown' || e.key === 'Enter') renderDropdown(searchEl.value);
    return;
  }
  if (e.key === 'ArrowDown') {
    ddActiveIdx = Math.min(ddActiveIdx + 1, items.length - 1);
  } else if (e.key === 'ArrowUp') {
    ddActiveIdx = Math.max(ddActiveIdx - 1, 0);
  } else if (e.key === 'Enter') {
    if (ddActiveIdx >= 0 && items[ddActiveIdx]) {
      items[ddActiveIdx].click();
    } else if (ddFiltered.length === 1) {
      selectUni(ddFiltered[0].kode);
    }
    return;
  } else if (e.key === 'Escape') {
    dropdown.classList.remove('open');
    return;
  }
  items.forEach((el, i) => el.classList.toggle('active', i === ddActiveIdx));
  if (items[ddActiveIdx]) items[ddActiveIdx].scrollIntoView({ block: 'nearest' });
});

searchEl.addEventListener('input', e => {
  const q = e.target.value.trim();
  if (selectedUni && q !== selectedUni.nama) {
    selectedUni = null;
    selDisplay.classList.remove('show');
    btnClear.classList.remove('visible');
    btnLoad.disabled = true;
    btnLoad.textContent = 'Pilih universitas terlebih dahulu';
  }
  renderDropdown(q);
});

searchEl.addEventListener('focus', () => {
  if (!selectedUni) renderDropdown(searchEl.value);
});

document.addEventListener('click', e => {
  if (!document.getElementById('combobox-wrap').contains(e.target)) {
    dropdown.classList.remove('open');
  }
});

// ── DATA LOADING ──────────────────────────────────────────────────────────────
function setStatus(show, text) {
  document.getElementById('status-area').style.display = show ? 'block' : 'none';
  if (text) document.getElementById('status-text').textContent = text;
}

function setError(msg) {
  const el = document.getElementById('error-area');
  el.style.display = msg ? 'block' : 'none';
  el.innerHTML = msg || '';
}

async function loadData() {
  if (!selectedUni) return;
  const ptnId = selectedUni.kode;

  setError(null);
  hideResults();
  setStatus(true, `Mengambil data ${selectedUni.nama}...`);
  btnLoad.disabled = true;

  try {
    const res = await fetch(`data/${ptnId}.json`);
    if (!res.ok) {
      if (res.status === 404) throw new Error(`Data untuk PTN ini belum tersedia. Jalankan <code>python crawl_snbt.py</code> untuk mengunduh data.`);
      throw new Error(`HTTP ${res.status}`);
    }
    const json = await res.json();

    document.getElementById('ptn-name').textContent = selectedUni.nama;
    document.getElementById('ptn-kota').textContent = `${selectedUni.kota} · ${selectedUni.provinsi}`;
    document.getElementById('ptn-prodi-count').textContent = json.prodi_count ? `${json.prodi_count} Program Studi` : '—';
    const webEl = document.getElementById('ptn-web');
    if (json.web) { webEl.href = json.web; webEl.style.display = ''; }
    else { webEl.style.display = 'none'; }

    const data = json.data || [];
    if (data.length === 0) throw new Error(`Tidak ada data prodi ditemukan untuk PTN <strong>${selectedUni.nama}</strong>.`);

    allData = data;
    updateSummary();
    render();
    setStatus(false);

    document.getElementById('ptn-info').style.display = 'block';
    document.getElementById('summary-area').style.display = 'block';
    document.getElementById('controls-area').style.display = 'block';
    document.getElementById('table-area').style.display = 'block';

  } catch (e) {
    setStatus(false);
    setError(`<strong>Gagal memuat data.</strong> ${e.message}`);
  } finally {
    btnLoad.disabled = false;
    btnLoad.textContent = `Lihat Prodi ${selectedUni.nama.split(' ').slice(0, 3).join(' ')} →`;
  }
}

// ── TABLE RENDER ──────────────────────────────────────────────────────────────
function updateSummary() {
  const valid = allData.filter(r => r.peluang !== null);
  document.getElementById('s-total').textContent = valid.length;
  document.getElementById('s-high').textContent  = valid.filter(r => r.peluang >= 30).length;
  document.getElementById('s-mid').textContent   = valid.filter(r => r.peluang >= 10 && r.peluang < 30).length;
  document.getElementById('s-low').textContent   = valid.filter(r => r.peluang < 10).length;
}

function setSort(key) {
  const full = key.includes('_') ? key : key + '_desc';
  if (currentSort === full) currentSort = full.replace('_desc', '_asc');
  else currentSort = full;
  document.getElementById('q-sort').value = currentSort;
  render();
}

function badgeClass(p) {
  if (p === null) return 'badge-gray';
  if (p >= 30) return 'badge-green';
  if (p >= 10) return 'badge-amber';
  return 'badge-red';
}

function barColor(p) {
  if (p === null) return 'rgba(255,255,255,.1)';
  if (p >= 30) return 'var(--green)';
  if (p >= 10) return 'var(--amber)';
  return 'var(--red)';
}

function render() {
  const q       = document.getElementById('q-search').value.toLowerCase();
  const jenjang = document.getElementById('q-jenjang').value;
  const filter  = document.getElementById('q-filter').value;
  currentSort   = document.getElementById('q-sort').value;

  let d = allData.filter(r => {
    if (!r.nama.toLowerCase().includes(q)) return false;
    if (jenjang && r.jenjang !== jenjang) return false;
    if (filter === 'high' && (r.peluang === null || r.peluang < 30))  return false;
    if (filter === 'mid'  && (r.peluang === null || r.peluang < 10 || r.peluang >= 30)) return false;
    if (filter === 'low'  && (r.peluang === null || r.peluang >= 10)) return false;
    return true;
  });

  const sortFns = {
    p_desc:       (a, b) => (b.peluang ?? -1) - (a.peluang ?? -1),
    p_asc:        (a, b) => (a.peluang ?? 9999) - (b.peluang ?? 9999),
    peminat_desc: (a, b) => (b.peminat ?? 0) - (a.peminat ?? 0),
    peminat_asc:  (a, b) => (a.peminat ?? 9999) - (b.peminat ?? 9999),
    tampung_desc: (a, b) => (b.tampung ?? 0) - (a.tampung ?? 0),
    tampung_asc:  (a, b) => (a.tampung ?? 9999) - (b.tampung ?? 9999),
    nama:         (a, b) => a.nama.localeCompare(b.nama, 'id'),
    nama_asc:     (a, b) => a.nama.localeCompare(b.nama, 'id'),
  };
  d.sort(sortFns[currentSort] || sortFns.p_desc);

  ['nama', 'tampung', 'peminat', 'peluang'].forEach(k => {
    const th = document.getElementById('th-' + k);
    if (!th) return;
    const span = th.querySelector('.arr');
    const active = currentSort.startsWith(k) || (k === 'peluang' && currentSort.startsWith('p'));
    th.classList.toggle('active', active);
    if (span) span.textContent = !active ? '↕' : currentSort.endsWith('_asc') ? '↑' : '↓';
  });

  const maxP = Math.max(...d.filter(r => r.peluang !== null).map(r => r.peluang), 1);
  document.getElementById('row-count').textContent = `${d.length} prodi`;

  const tbody = document.getElementById('tbody');
  if (d.length === 0) {
    tbody.innerHTML = `<tr><td colspan="6"><div class="empty-state">Tidak ada prodi yang cocok.</div></td></tr>`;
    return;
  }

  tbody.innerHTML = d.map((r, i) => {
    const pLabel = r.peluang !== null ? r.peluang.toFixed(1) + '%' : 'N/A';
    const barW   = r.peluang !== null ? Math.min(100, (r.peluang / Math.max(maxP, 50)) * 100) : 0;
    const jBadge = r.jenjang === 'Sarjana Terapan'
      ? '<span class="badge badge-d4">D4</span>'
      : '<span class="badge badge-s1">S1</span>';
    return `<tr style="animation:fadeIn .25s ease both;animation-delay:${Math.min(i, .15) * 0.03}s">
      <td>
        <div class="td-nama">${r.nama}</div>
        <div class="td-kode">${r.kode}</div>
      </td>
      <td class="td-num ${r.tampung ? '' : 'td-num-muted'}">${r.tampung ?? '—'}</td>
      <td class="td-num ${r.peminat ? '' : 'td-num-muted'}">${r.peminat ? r.peminat.toLocaleString('id-ID') : '—'}</td>
      <td>${jBadge}</td>
      <td><span class="badge ${badgeClass(r.peluang)}">${pLabel}</span></td>
      <td>
        <div class="bar-wrap">
          <div style="font-size:10px;color:var(--text-dim);font-family:'DM Mono',monospace;text-align:right">${r.tampung ?? '—'} / ${r.peminat ? r.peminat.toLocaleString('id-ID') : '—'}</div>
          <div class="bar-track"><div class="bar-fill" style="width:${barW.toFixed(1)}%;background:${barColor(r.peluang)}"></div></div>
        </div>
      </td>
    </tr>`;
  }).join('');
}
</script>
</body>
</html>
